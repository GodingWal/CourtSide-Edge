# CourtSideEdge AGENT tier env — copy to deploy/env/agents.env and fill in.
# Consumed by: docker compose --env-file deploy/env/agents.env -f deploy/docker-compose.agents.yml
# Runs on the vast.ai box; everything points back at the VPS.

# ── Redis on the VPS ──────────────────────────────────────────────────────
# Public IP of the VPS. The agents dial in over the network.
REDIS_HOST=76.13.100.125
REDIS_PORT=6379
# Must match REDIS_PASSWORD in deploy/env/web.env on the VPS.
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── PostgreSQL on the VPS (recommended) ───────────────────────────────────
# When the VPS runs Postgres (COMPOSE_PROFILES=postgres in web.env), point the
# agents straight at it — they then read/write the ledger directly instead of
# relying on the HTTP audit fallback and Redis mirrors. Allow this box's IP
# through the VPS firewall on 5432 (same model as Redis below).
# DATABASE_URL=postgresql://courtside:CHANGE_ME_POSTGRES_PASSWORD@76.13.100.125:5432/courtside

# ── Web backend on the VPS ────────────────────────────────────────────────
# Audit logging: without DATABASE_URL, agents on this box have no ledger, so
# AuditLogger POSTs decisions to BACKEND_URL/api/audit using API_KEY.
BACKEND_URL=https://courtside-edge.com
# Bearer token — must match API_KEY in deploy/env/web.env.
API_KEY=CHANGE_ME_API_KEY

# Agent 18 (liquidity limits) endpoint for Agent 8's sizing cap. The compose
# service name resolves inside the agent tier network.
AGENT18_URL=http://agent_18_liquidity_oracle:8014

# ── Bookmaker odds & player props (the-odds-api.com) ───────────────────────
# Free tier is ~500 credits/month — keep the poll interval high.
ODDS_API_KEY=
ODDS_POLL_SECONDS=7200
ODDS_MAX_PROP_EVENTS=2
# Player props come from DFS pick'em platforms (the ones we play on).
ODDS_PROP_BOOKMAKERS=prizepicks,underdog

# ── LLM (local Hermes via Ollama by default; see HERMES_* in client) ───────
# From inside containers, localhost is the container itself - host.docker.internal
# (mapped via extra_hosts in the compose file) reaches the host's Ollama.
HERMES_BASE_URL=http://host.docker.internal:11434/v1
HERMES_API_KEY=

# ── Execution alerts (Agent 4) — optional; leave blank to disable ──────────
# Telegram: create a bot via @BotFather, then put your chat id here.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Discord: channel webhook URL (Server Settings → Integrations → Webhooks).
DISCORD_WEBHOOK_URL=
