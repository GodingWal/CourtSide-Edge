# CourtSideEdge WEB tier env — copy to deploy/env/web.env and fill in.
# Consumed by: docker compose --env-file deploy/env/web.env -f deploy/docker-compose.web.yml
# (used both for ${VAR} interpolation in the compose file AND injected into containers)

# ── Runtime ───────────────────────────────────────────────────────────────
NODE_ENV=production

# ── API auth ──────────────────────────────────────────────────────────────
# Bearer token enforced on every /api request. The host nginx injects this on
# behalf of the browser, so it stays server-side. Generate: openssl rand -hex 32
API_KEY=CHANGE_ME_API_KEY

# Public dashboard origin (CORS allow-list on the server).
FRONTEND_URL=https://courtside-edge.com

# Dashboard login (nginx basic auth). Required: nginx injects API_KEY for
# logged-in visitors, so without this gate the API is effectively public.
# gen-secrets.sh fills these in; install-nginx.sh builds the htpasswd file.
DASHBOARD_USER=courtside
DASHBOARD_PASSWORD=CHANGE_ME_DASHBOARD_PASSWORD

# Agent 13 (parlay generator) endpoint. The compose service name resolves
# inside the web tier network; localhost only works outside Docker.
AGENT13_URL=http://agent_13_parlay_generator:8009
# How far before tipoff pick'em entries may be generated (default 12h; pick'em
# slips lock at tipoff, so same-day generation is normal).
PARLAY_PREGAME_WINDOW_MINUTES=720

# ── Database ──────────────────────────────────────────────────────────────
# SQLite path inside the container (./data is bind-mounted to /app/data).
# Used only when DATABASE_URL below is not set.
DATABASE_PATH=/app/data/hoopstats_wnba.db

# PostgreSQL (recommended): uncomment all three to run the ledger on the
# bundled postgres service instead of the SQLite file. DATABASE_URL is read
# by the web server AND the Python agents (it replaces the file path, the
# HTTP audit fallback, and the Redis bankroll mirror as the source of truth).
# One-time data copy: deploy/scripts/migrate_sqlite_to_postgres.py
# COMPOSE_PROFILES=postgres
# POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
# DATABASE_URL=postgresql://courtside:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/courtside

# ── Redis ─────────────────────────────────────────────────────────────────
# REDIS_PASSWORD must match agents.env on the vast.ai box.
# Generate: openssl rand -hex 24
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_HOST=redis
REDIS_PORT=6379
# The Express server reads REDIS_URL (keep the password in sync with the above).
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379

# ── LLM (local Hermes via Ollama; see infrastructure/hermes/client.py).
# When unreachable, LLM-driven agents skip items instead of fabricating data.
# From inside containers, localhost is the container itself - host.docker.internal
# (mapped via extra_hosts in the compose files) reaches the host's Ollama.
HERMES_BASE_URL=http://host.docker.internal:11434/v1
HERMES_MODEL=hermes3
HERMES_API_KEY=local
# Reply budget for free-form analysis (Agent 12 chat); JSON extraction is unaffected.
HERMES_MAX_TOKENS=1024
