# Copy to .env and fill in values. Compose injects this file into every service.

# --- Redis (inter-agent pub/sub + streams) ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Web server (web/server) ---
# In production the server refuses to start without an API key.
# All /api endpoints and WebSocket connections require `Authorization: Bearer <API_KEY>`.
NODE_ENV=development
API_KEY=
# Origin allowed by CORS (the dashboard URL)
FRONTEND_URL=http://localhost:5173
# SQLite database path (shared volume ./data)
DATABASE_PATH=./data/hoopstats_wnba.db

# --- Web client (web/client, Vite build-time) ---
VITE_API_BASE=http://localhost:3000/api

# --- LLM integration (infrastructure/nemotron) ---
NVIDIA_API_KEY=
