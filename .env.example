# Copy to .env and fill in values. Compose injects this file into every service.

# --- Redis (inter-agent pub/sub + streams) ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Web server (web/server) ---
# In production the server refuses to start without an API key.
# All /api endpoints and WebSocket connections require `Authorization: Bearer <API_KEY>`.
NODE_ENV=development
API_KEY=
# Origin allowed by CORS (the dashboard URL)
FRONTEND_URL=http://localhost:5173
# SQLite database path (shared volume ./data)
DATABASE_PATH=./data/hoopstats_wnba.db

# --- PostgreSQL (recommended) ---
# Uncomment the three lines below to run the stack on PostgreSQL instead of
# SQLite: COMPOSE_PROFILES starts the postgres service, DATABASE_URL switches
# the web server AND every Python agent over to it (DATABASE_PATH is then
# ignored). One-time data copy: deploy/scripts/migrate_sqlite_to_postgres.py
# COMPOSE_PROFILES=postgres
# POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
# DATABASE_URL=postgresql://courtside:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/courtside

# --- Web client (web/client, Vite build-time) ---
VITE_API_BASE=http://localhost:3000/api

# --- LLM integration (infrastructure/hermes) ---
HERMES_API_KEY=
