# CourtSideEdge Server Environment Variables

# The port where the Express server will listen (default: 3000)
PORT=3000

# Redis connection URL (default: redis://localhost:6379)
REDIS_URL=redis://localhost:6379

# Path to the SQLite database file (default: absolute path to data/hoopstats_wnba.db)
DATABASE_PATH=../../data/hoopstats_wnba.db

# Application environment (development | production | test)
NODE_ENV=development
