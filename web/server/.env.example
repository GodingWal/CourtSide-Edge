# ── CourtSideEdge Server Environment Variables ───────────────────────────────

# Server port (default: 3000)
PORT=3000

# Redis connection URL (default: redis://localhost:6379)
REDIS_URL=redis://localhost:6379

# SQLite database file path (default: ../../data/hoopstats_wnba.db relative to server)
# DATABASE_PATH=./data/hoopstats_wnba.db

# Environment mode: 'development' | 'production' | 'test'
NODE_ENV=development

# API authentication key (REQUIRED in production mode)
# All /api/* endpoints require Authorization: Bearer <API_KEY> header in production
# API_KEY=your-secret-api-key-here
